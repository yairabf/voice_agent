DEFAULT_PROFILE=voice-agent
SESSION_TIMEOUT=30m
MAX_SESSIONS=1
TELEPHONY_MAX_CALLS=8
AUDIO_MAX_BUFFERED_FRAMES=16
LOG_LEVEL=debug
VOICE_RUNTIME_PORT=8088
# Self-hosted LiveKit connection settings. Use generated local/dev credentials or managed
# production secrets; never commit real API secrets.
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
# simulated for CI/local HTTP event tests; set sdk to create rooms and attach an RTC
# listener that subscribes to LiveKit audio tracks after webhook-created calls.
LIVEKIT_CONTROL_MODE=simulated
# Protects simulated event ingestion and call/room metadata APIs. LiveKit's real
# webhook JWT is also accepted at /telephony/livekit/webhook when API credentials are set.
# Local/dev clients send this value as an Authorization: Bearer *** header. Replace it.
TELEPHONY_EVENT_TOKEN=change-me-local-dev-token
TELEPHONY_CALL_HISTORY_LIMIT=100

# HERMES_INTEGRATION_MODE=api fails clearly rather than shelling out to Hermes CLI.
HERMES_INTEGRATION_MODE=fake
DEPLOYED_AT=
