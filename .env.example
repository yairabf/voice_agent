DEFAULT_PROFILE=voice-agent
SESSION_TIMEOUT=30m
MAX_SESSIONS=1
TELEPHONY_MAX_CALLS=8
AUDIO_MAX_BUFFERED_FRAMES=16
LOG_LEVEL=debug
VOICE_RUNTIME_PORT=8088
# Self-hosted LiveKit connection settings. Use generated local/dev credentials or managed
# production secrets; never commit real API secrets.
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
# simulated for CI/local HTTP event tests; set sdk to use livekit-api room create/delete.
LIVEKIT_CONTROL_MODE=simulated
# Optional in simulated/local mode. Required when LIVEKIT_CONTROL_MODE=sdk.
# Clients send it as an Authorization: Bearer header.
TELEPHONY_EVENT_TOKEN=

# HERMES_INTEGRATION_MODE=api fails clearly rather than shelling out to Hermes CLI.
HERMES_INTEGRATION_MODE=fake
DEPLOYED_AT=
